# Request-time latency path — target p99 < 50ms
# Render: d2 03_latency_path.d2 03_latency_path.svg

vars: {
  d2-config: {
    layout-engine: dagre
    pad: 40
  }
}

title: |md
  # Request-Time Latency Path
| { near: top-center; style: { font-size: 26; bold: true; font-color: "#1B3139" } }

flow: "" {
  shape: sequence_diagram

  app: App /score { style: { fill: "#FFD9D0"; stroke: "#FF3621"; stroke-width: 2 } }
  rules: Stage-0 rules { style: { fill: "#FFECE7"; stroke: "#FF3621"; stroke-width: 2 } }
  ep: Serving endpoint { style: { fill: "#FFD9D0"; stroke: "#FF3621"; stroke-width: 2 } }
  lb: Lakebase online store { style: { fill: "#E8EDEE"; stroke: "#1B3139"; stroke-width: 2 } }
  m: LightGBM { style: { fill: "#1B3139"; stroke: "#1B3139"; font-color: "#FFFFFF" } }

  app -> rules: evaluate cheap pre-filters (<1ms) { style.stroke: "#1B3139" }

  fired: rule fires {
    rules -> app: blocked — short-circuit { style.stroke: "#FF3621" }
  }

  passes: passes to model {
    app -> ep: query(keys + amount + event_ts) { style.stroke: "#1B3139" }
    ep -> lb: point lookups\ncounters · daily · monthly · profile { style.stroke: "#1B3139" }
    lb -> ep: feature values (~ms) { style.stroke: "#1B3139" }
    ep -> ep: compute on-demand UDFs { style.stroke: "#1B3139" }
    ep -> m: inference { style.stroke: "#1B3139" }
    m -> ep: score { style.stroke: "#1B3139" }
    ep -> app: decision + latency_ms { style.stroke: "#FF3621" }
  }
}

note: |md
  End-to-end p50/p90/p99 recorded by `06_benchmark` and the App dashboard.
| { near: bottom-center; style: { font-size: 14; font-color: "#1B3139"; fill: "#FBFAF8" } }
